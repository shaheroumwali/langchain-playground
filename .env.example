# Google Generative AI API Configuration
# Get your API key from: https://aistudio.google.com/app/apikeys
GOOGLE_API_KEY=your_google_api_key_here

# LLM Model Configuration
# Available models: gemini-2.5-flash, gemini-1.5-pro, gemini-1.5-flash, etc.
# Default: gemini-2.5-flash
MODEL_NAME=gemini-2.5-flash

# Temperature controls randomness/creativity in responses
# Range: 0.0 (deterministic) to 1.0 (creative)
# Default: 0.7
TEMPERATURE=0.7

# System message that defines the chatbot's personality and behavior
# Default: "You are a helpful Python tutor who explains concepts clearly."
SYSTEM_MESSAGE=You are a helpful Python tutor who explains concepts clearly.

# Database Configuration (Optional)
# Path to SQLite database file
# Default: chat_history.db
DATABASE_PATH=chat_history.db

# API Server Configuration (Optional)
# Host and port for the FastAPI server
# API_HOST=0.0.0.0
# API_PORT=8085
